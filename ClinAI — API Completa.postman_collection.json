{
  "info": {
    "_postman_id": "7a99ec04-e208-4245-8559-a6368c17fc40",
    "name": "ClinAI — API Completa",
    "description": "Sistema Clínico Digital Interoperable. Autenticación: POST /auth/login con X-Access-Key + X-Permission-Key → guarda {{token}} en variable. Todos los demás endpoints usan Bearer {{token}}. Variables: base_url, orch_url, ml_url, dl_url, rag_url.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "26953276"
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login usuario",
          "request": {
            "auth": {
              "type": "apikey"
            },
            "method": "POST",
            "header": [
              {
                "key": "X-Access-Key",
                "value": "{{access_key}}"
              },
              {
                "key": "X-Permission-Key",
                "value": "{{permission_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@clinai.me\",\n  \"password\": \"SecurePass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Registro usuario (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"medico@clinai.me\",\n  \"password\": \"Pass1234!\",\n  \"role\": \"MEDICO\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Perfil usuario autenticado",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refrescar token JWT",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          },
          "response": []
        }
      ],
      "description": "Autenticación JWT — doble API-Key (X-Access-Key + X-Permission-Key) → JWT Bearer. El pre-request script guarda el token automáticamente."
    },
