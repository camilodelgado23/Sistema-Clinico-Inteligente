# ─────────────────────────────────────────────
# PostgreSQL (docker-compose local)
# ─────────────────────────────────────────────
POSTGRES_PASSWORD=clinai_secret
DATABASE_URL=postgresql://clinai:clinai_secret@postgres:5432/clinai_db

# ─────────────────────────────────────────────
# Security — JWT + AES-256 / Fernet
# ─────────────────────────────────────────────
JWT_SECRET=change_me_32_chars_minimum_random
JWT_EXPIRE_HOURS=8
AES_KEY=change_me_64_hex_chars_minimum
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change_me_fernet_key_base64urlsafe

# Superuser JWT (médico externo) — clave separada
SUPERUSER_JWT_SECRET=change_me_superuser_jwt_secret

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost,https://tu-dominio.com

# ─────────────────────────────────────────────
# MinIO
# ─────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_SERVER_URL=http://localhost:9000
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=clinical-images

# ─────────────────────────────────────────────
# Microservices
# ─────────────────────────────────────────────
ML_SERVICE_URL=http://ml-service:8001
DL_SERVICE_URL=http://dl-service:8002
ORCHESTRATOR_URL=http://orchestrator:8003
RAG_AGENT_URL=http://rag-agent:8004
FHIR_SERVER_URL=http://fhir-server:8080/fhir

# ─────────────────────────────────────────────
# Redis (memoria agente RAG)
# ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────
# LLM para el Agente RAG
# Opciones: groq, openai, anthropic, ollama
# ─────────────────────────────────────────────
LLM_PROVIDER=groq
# Groq (recomendado — gratuito): https://console.groq.com
GROQ_API_KEY=gsk_change_me
# OpenAI (alternativa)
OPENAI_API_KEY=sk-change_me
# Anthropic (alternativa)
ANTHROPIC_API_KEY=sk-ant-change_me
# Modelo a usar (groq: llama-3.3-70b-versatile | openai: gpt-4o-mini)
LLM_MODEL=llama-3.3-70b-versatile

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
